{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$esbuild",
      "label": "npm: build",
      "detail": "Bundle the extension with esbuild"
    },
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": "$esbuild-watch",
      "label": "npm: watch",
      "detail": "Rebuild the extension on change"
    }
  ]
}
