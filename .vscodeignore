.github/**
src/**
test/**
docs/**
node_modules/**
**/*.ts
**/*.map
esbuild.js
eslint.config.mjs
vitest.config.ts
tsconfig.json
.prettierrc.json
.prettierignore
.gitignore
.eslintcache
